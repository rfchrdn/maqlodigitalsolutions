{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project entity",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "github": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "description", "imageUrl"]
    },
    "User": {
      "title": "User",
      "description": "User profile for admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User metadata"
    }
  }
}
